#!/usr/bin/env bash
# obsctl - Obsidian vault control tool
# Usage: obsctl <command> [args...]

set -euo pipefail

# Configuration
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/obsctl"
CONFIG_FILE="$CONFIG_DIR/config.json"

# Defaults (overridable by config.json or env vars)
CONTAINER="${OBS_CONTAINER:-obsctl}"
VAULT_PREFIX="${OBS_VAULT_PREFIX:-Documents/Obsidian}"
OBSIDIAN_USER="${OBS_USER:-obsidian}"

# Load config if exists
if [[ -f "$CONFIG_FILE" ]]; then
    _cfg_container=$(grep -o '"container"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*: *"//;s/"//')
    _cfg_prefix=$(grep -o '"vaultPrefix"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*: *"//;s/"//')
    _cfg_user=$(grep -o '"user"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*: *"//;s/"//')
    [[ -n "${_cfg_container:-}" ]] && CONTAINER="${OBS_CONTAINER:-$_cfg_container}"
    [[ -n "${_cfg_prefix:-}" ]] && VAULT_PREFIX="${OBS_VAULT_PREFIX:-$_cfg_prefix}"
    [[ -n "${_cfg_user:-}" ]] && OBSIDIAN_USER="${OBS_USER:-$_cfg_user}"
fi

# --- Path resolution ---
# path=, folder=, to= → auto-prefix with VAULT_PREFIX
# file=, name=, query= → pass through (wikilink resolution)
resolve_arg() {
    local arg="$1"
    case "$arg" in
        path=*|folder=*|to=*)
            local key="${arg%%=*}"
            local val="${arg#*=}"
            # Strip surrounding quotes if present
            val="${val%\"}"
            val="${val#\"}"
            if [[ "$val" != "$VAULT_PREFIX"* ]]; then
                val="$VAULT_PREFIX/$val"
            fi
            echo "${key}=\"${val}\""
            ;;
        file=*|name=*|query=*|content=*|limit=*|format=*|line=*|sort=*)
            echo "$arg"
            ;;
        *)
            echo "$arg"
            ;;
    esac
}

# --- Shorthand expansion (sets CMD and ARGS array) ---
expand_command() {
    case "$1" in
        ls)       CMD="files" ;;
        mv)       CMD="move" ;;
        rm)       CMD="delete" ;;
        props)    CMD="properties" ;;
        today)    CMD="daily:read" ;;
        today:add)CMD="daily:append" ;;
        search)   CMD="search:context" ;;
        tags)     CMD="tags"; EXTRA_ARGS=("counts" "sort=count") ;;
        *)        CMD="$1" ;;
    esac
}

# --- Bare argument heuristic ---
# If a bare arg (no key=) contains /, treat as path and prefix
# If no /, leave as-is (wikilink name resolution)
resolve_bare_arg() {
    local cmd="$1"
    local arg="$2"
    # Skip if already a key=value pair
    [[ "$arg" == *=* ]] && { echo "$arg"; return; }
    # Skip flags
    [[ "$arg" == -* ]] && { echo "$arg"; return; }

    case "$cmd" in
        read|outline|delete|properties)
            if [[ "$arg" == */* ]]; then
                echo "path=\"$VAULT_PREFIX/$arg\""
            else
                echo "file=\"$arg\""
            fi
            ;;
        files|folders)
            if [[ "$arg" == */* ]] || [[ -z "$arg" ]]; then
                echo "folder=\"$VAULT_PREFIX/$arg\""
            else
                echo "folder=\"$VAULT_PREFIX/$arg\""
            fi
            ;;
        search|search:context)
            echo "query=\"$arg\""
            ;;
        move)
            if [[ "$arg" == */* ]]; then
                echo "\"$VAULT_PREFIX/$arg\""
            else
                echo "\"$arg\""
            fi
            ;;
        *)
            echo "\"$arg\""
            ;;
    esac
}

# --- Container check ---
check_container() {
    if ! docker inspect "$CONTAINER" &>/dev/null; then
        echo "Error: Container '$CONTAINER' not found." >&2
        echo "Run 'obsctl setup' to configure." >&2
        exit 1
    fi
    if [[ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null)" != "true" ]]; then
        echo "Error: Container '$CONTAINER' is not running." >&2
        echo "Run: docker compose up -d" >&2
        exit 1
    fi
}

# --- Execute obsidian CLI command ---
# Uses the native obsidian-cli binary (introduced in Obsidian 1.12.7)
# The Electron app (obsidian --no-sandbox) has a silent-failure bug on
# large vaults for search/tags. See:
#   https://forum.obsidian.md/t/search-cli-returns-nothing-with-large-vault-not-even-no-results/112519
exec_obsidian() {
    docker exec -u "$OBSIDIAN_USER" "$CONTAINER" \
        /opt/obsidian/obsidian-cli "$@" 2>/dev/null
}

# --- Built-in commands ---

do_setup() {
    echo "obsctl setup — Interactive Configuration"
    echo ""

    # Determine project directory (where Dockerfile lives)
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

    mkdir -p "$CONFIG_DIR"

    # --- Step 1: Docker check ---
    echo "[1/6] Docker"
    if ! command -v docker &>/dev/null; then
        echo "  ✗ Docker not found. Install Docker first: https://docs.docker.com/get-docker/"
        exit 1
    fi
    local docker_ver
    docker_ver=$(docker --version 2>/dev/null | grep -oP '\d+\.\d+\.\d+' | head -1)
    echo "  ✓ Docker Engine detected (v${docker_ver})"

    if ! docker compose version &>/dev/null; then
        echo "  ✗ Docker Compose v2 not found. Install: https://docs.docker.com/compose/install/"
        exit 1
    fi
    echo "  ✓ Docker Compose v2 detected"

    # --- Step 2: Vault location ---
    echo ""
    echo "[2/6] Vault Location"
    local default_vault="$script_dir/vault"
    local vault_path
    if [[ -f "$CONFIG_FILE" ]]; then
        vault_path=$(grep -o '"vault"[[:space:]]*:[[:space:]]*"[^"]*"' "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*: *"//;s/"//')
    fi
    vault_path="${vault_path:-$default_vault}"

    read -rp "  Vault location [$vault_path]: " input_vault
    vault_path="${input_vault:-$vault_path}"
    vault_path="${vault_path/#\~/$HOME}"
    mkdir -p "$vault_path"
    echo "  ✓ Vault: $vault_path"

    # --- Step 3: OneDrive sync folder ---
    echo ""
    echo "[3/6] OneDrive Sync"
    local default_sync="/Documents/Obsidian"
    local sync_folder="$default_sync"
    read -rp "  OneDrive folder to sync [$sync_folder]: " input_sync
    sync_folder="${input_sync:-$sync_folder}"
    VAULT_PREFIX="${sync_folder#/}"
    echo "  ✓ Sync folder: $sync_folder"

    # --- Step 4: Container ---
    echo ""
    echo "[4/6] Container"
    local compose_dir="$script_dir"
    if [[ ! -f "$compose_dir/docker-compose.yml" ]]; then
        echo "  ✗ docker-compose.yml not found in $compose_dir"
        echo "    Clone the obsctl repo first: git clone <repo-url>"
        exit 1
    fi

    # Write .env if not exists
    if [[ ! -f "$compose_dir/.env" ]]; then
        echo "PUID=$(id -u)" > "$compose_dir/.env"
        echo "PGID=$(id -g)" >> "$compose_dir/.env"
        echo "VAULT_NAME=MyVault" >> "$compose_dir/.env"
        echo "  ✓ Created .env (PUID=$(id -u), PGID=$(id -g))"
    else
        echo "  ✓ .env exists"
    fi

    # Build image (needed for auth step)
    echo "  → Building image..."
    (cd "$compose_dir" && docker compose build 2>&1) || {
        echo "  ✗ Failed to build image"
        exit 1
    }
    echo "  ✓ Image built"

    # --- Step 5: OneDrive authentication (BEFORE starting container) ---
    echo ""
    echo "[5/6] OneDrive Authentication"
    local onedrive_conf="$compose_dir/onedrive-conf"
    mkdir -p "$onedrive_conf"

    if [[ -f "$onedrive_conf/refresh_token" ]]; then
        echo "  ✓ Already authenticated (refresh_token exists)"
    else
        echo "  → Starting OneDrive authentication..."
        echo "  A URL will appear below. Open it in your browser,"
        echo "  sign in, then paste the redirect URI back here."
        echo ""
        (cd "$compose_dir" && docker compose run --rm --entrypoint "" obsctl \
            gosu obsidian onedrive --confdir=/onedrive-conf --synchronize --single-directory '')

        if [[ -f "$onedrive_conf/refresh_token" ]]; then
            echo "  ✓ Authentication successful"
        else
            echo "  ✗ Authentication failed. Please try again."
            exit 1
        fi
    fi

    # --- Start container (after auth is ready) ---
    echo ""
    echo "  → Starting container..."
    (cd "$compose_dir" && docker compose up -d 2>&1) || {
        echo "  ✗ Failed to start container"
        exit 1
    }
    echo "  ✓ Container started"

    # Wait for healthy
    echo "  → Waiting for container to be healthy..."
    local attempts=0
    while [[ $attempts -lt 30 ]]; do
        local health
        health=$(docker inspect -f '{{.State.Health.Status}}' "$CONTAINER" 2>/dev/null || echo "unknown")
        if [[ "$health" == "healthy" ]]; then
            echo "  ✓ Container healthy"
            break
        fi
        attempts=$((attempts + 1))
        sleep 2
    done
    if [[ $attempts -ge 30 ]]; then
        echo "  ✗ Container did not become healthy in 60s"
        echo "    Check: docker compose logs"
        exit 1
    fi

    # Write sync_list if not exists
    if [[ ! -f "$onedrive_conf/sync_list" ]]; then
        echo "$sync_folder" > "$onedrive_conf/sync_list"
        echo "  ✓ Created sync_list: $sync_folder"
    fi

    # --- Step 6: Write config ---
    echo ""
    echo "[6/6] Configuration"
    cat > "$CONFIG_FILE" <<CONF
{
  "vault": "$vault_path",
  "vaultPrefix": "$VAULT_PREFIX",
  "container": "$CONTAINER",
  "user": "$OBSIDIAN_USER",
  "projectDir": "$compose_dir",
  "onedrive": {
    "syncInterval": 600,
    "skipDotFiles": true,
    "syncFolder": "$sync_folder"
  }
}
CONF
    echo "  ✓ Config saved: $CONFIG_FILE"

    # --- Verify ---
    echo ""
    echo "Verifying..."
    local vault_info
    vault_info=$(exec_obsidian vault 2>/dev/null) || true
    if [[ -n "$vault_info" ]]; then
        local files folders
        files=$(echo "$vault_info" | grep "^files" | awk '{print $2}')
        folders=$(echo "$vault_info" | grep "^folders" | awk '{print $2}')
        echo "  ✓ Obsidian CLI active ($files files, $folders folders)"
    else
        echo "  ⚠ Obsidian CLI not responding. It may need a moment to initialize."
    fi

    local onedrive_pid
    onedrive_pid=$(docker exec "$CONTAINER" pgrep -f "onedrive.*monitor" 2>/dev/null || true)
    if [[ -n "$onedrive_pid" ]]; then
        echo "  ✓ OneDrive sync active"
    else
        echo "  ⚠ OneDrive not running. Check: docker compose logs"
    fi

    echo ""
    echo "Setup complete! Try: obsctl vault"
}

do_status() {
    check_container

    local container_status
    container_status=$(docker inspect -f '{{.State.Status}}' "$CONTAINER" 2>/dev/null)
    local container_health
    container_health=$(docker inspect -f '{{.State.Health.Status}}' "$CONTAINER" 2>/dev/null || echo "unknown")
    local uptime
    uptime=$(docker inspect -f '{{.State.StartedAt}}' "$CONTAINER" 2>/dev/null | cut -dT -f1)

    echo "Container:  $CONTAINER ($container_health, since $uptime)"

    local vault_info
    vault_info=$(exec_obsidian vault 2>/dev/null) || true
    if [[ -n "$vault_info" ]]; then
        local files folders
        files=$(echo "$vault_info" | grep "^files" | awk '{print $2}')
        folders=$(echo "$vault_info" | grep "^folders" | awk '{print $2}')
        echo "Obsidian:   CLI active ($files files, $folders folders)"
    else
        echo "Obsidian:   CLI not responding"
    fi

    local onedrive_pid
    onedrive_pid=$(docker exec "$CONTAINER" pgrep -f "onedrive.*monitor" 2>/dev/null || true)
    if [[ -n "$onedrive_pid" ]]; then
        echo "OneDrive:   syncing (pid $onedrive_pid)"
    else
        echo "OneDrive:   not running"
    fi

    echo "Config:     $CONFIG_FILE"
}

do_help() {
    cat <<'HELP'
obsctl - Obsidian vault control tool

Usage: obsctl <command> [args...]

Commands:
  setup                 Configure Docker, OneDrive, and vault
  status                Show environment health
  vault                 Vault info
  read <note>           Read a note (path or wikilink name)
  search <query>        Full-text search with context
  ls [folder]           List files in folder
  create <name>         Create a note
  mv <src> <dst>        Move/rename a note
  rm <note>             Delete a note (trash)
  props <note>          Show frontmatter properties
  prop:set <args>       Set a frontmatter property
  prop:get <args>       Read a frontmatter property
  today                 Read today's daily note
  today:add <text>      Append to today's daily note
  tags                  List all tags with counts
  backlinks <note>      Show incoming links
  unresolved            Find broken links
  outline <note>        Show heading outline
  help                  Show this help

Path resolution:
  Contains /  → vault path (auto-prefixed with Documents/Obsidian/)
  No /        → wikilink name resolution (no prefix)

Environment:
  OBS_CONTAINER     Container name (default: obsctl)
  OBS_VAULT_PREFIX  Vault path prefix (default: Documents/Obsidian)
  OBS_USER          Docker exec user (default: obsidian)

Config: ~/.config/obsctl/config.json
HELP
}

# --- Main ---

if [[ $# -eq 0 ]]; then
    do_help
    exit 0
fi

# Handle built-in commands first
case "$1" in
    setup)  do_setup; exit $? ;;
    status) do_status; exit $? ;;
    help)   do_help; exit 0 ;;
esac

# Expand shorthands (sets CMD, may set EXTRA_ARGS)
CMD=""
EXTRA_ARGS=()
expand_command "$1"
shift
args=("$@" "${EXTRA_ARGS[@]}")

# Check container for obsidian CLI commands
check_container

# Resolve arguments
resolved_args=()
for arg in "${args[@]}"; do
    if [[ "$arg" == *=* ]]; then
        resolved_args+=("$(resolve_arg "$arg")")
    else
        resolved_args+=("$(resolve_bare_arg "$CMD" "$arg")")
    fi
done

# Execute
eval exec_obsidian "$CMD" "${resolved_args[@]}"
